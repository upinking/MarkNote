{
  "name": "marknote",
  "version": "0.1.0",
  "description": "A lightweight cross-platform Markdown note editor.",
  "author": "Codex",
  "main": "electron/main.cjs",
  "scripts": {
    "build:wysiwyg": "vite build --config vite.wysiwyg.config.mjs && node scripts/copy-katex.cjs && node scripts/copy-lucide.cjs",
    "dev": "npm run build:wysiwyg && electron .",
    "build": "electron-builder",
    "package:mac": "npm run build:wysiwyg && node scripts/package-macos.cjs",
    "start": "npm run build:wysiwyg && electron .",
    "prebuild": "npm run build:wysiwyg",
    "mobile:dev": "vite --config vite.mobile.config.mjs",
    "mobile:build": "vite build --config vite.mobile.config.mjs",
    "mobile:sync": "npm run mobile:build && cap sync android",
    "mobile:open": "cap open android"
  },
  "build": {
    "appId": "com.codex.marknote",
    "productName": "MarkNote",
    "files": [
      "app/**/*",
      "build/**/*",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@milkdown/crepe": "^7.21.1",
    "@milkdown/kit": "^7.21.1",
    "dompurify": "^3.4.5",
    "katex": "^0.17.0",
    "lucide": "^1.22.0",
    "marked": "^18.0.4",
    "vite": "^8.0.14"
  }
}
